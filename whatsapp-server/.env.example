# WhatsApp Session API — Environment Configuration (Template)
# Copy this file to '.env' and fill in your actual credentials.

# Server port
PORT=3001

# Shared secret for API authentication (sent via X-WA-SECRET header)
API_SECRET=your_super_secret_shared_key_here

# PostgreSQL Connection URL (e.g. postgresql://user:pass@host:port/dbname)
# Note: Use a generic database name since this service is decoupled from AIMS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_service

# Session Behavior Modes:
# - "DAEMON": Keep all session sockets open at all times
# - "SLEEP": Lazy-load connections on request & disconnect when idle (recommended for RAM savings)
WHATSAPP_MODE=SLEEP

# Socket Idle Timeout in milliseconds (e.g. 5 minutes = 300000)
WHATSAPP_IDLE_TIMEOUT=300000

# Whether to immediately put session to sleep on queue completion (grace period 10s)
# - Set "true" to immediately disconnect the socket after the queue becomes empty.
# - Set "false" (default) to wait for WHATSAPP_IDLE_TIMEOUT instead.
WHATSAPP_SLEEP_ON_QUEUE_COMPLETION=false

# Default message queue settings (can be overridden per-session via API)
DEFAULT_MIN_DELAY_MS=5000
DEFAULT_MAX_DELAY_MS=15000
DEFAULT_MAX_DAILY_MESSAGES=50

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
